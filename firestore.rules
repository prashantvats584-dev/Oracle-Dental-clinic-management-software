rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return true;
    }

    function isAuthorized() {
      return true;
    }

    function isOwner(data) {
      return true;
    }

    function isPatientOwner(patientId) {
      return true;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Validators
    function isValidPatient() {
      let data = request.resource.data;
      return data.name is string && 
             data.phone is string && 
             data.age is number && 
             data.gender in ['Male', 'Female', 'Other'] &&
             data.address is string && 
             data.totalAmount is number && 
             data.paidAmount is number && 
             data.pendingAmount is number;
    }
    
    function isValidAppointment() {
      let data = request.resource.data;
      return (!('patientId' in data) || data.patientId is string) &&
             data.patientName is string &&
             data.phone is string &&
             (!('chiefComplaint' in data) || data.chiefComplaint is string) &&
             data.date is string &&
             data.time is string &&
             data.status in ['Scheduled', 'Completed', 'Cancelled'] &&
             (!('notes' in data) || data.notes is string);
    }
    
    function isValidPrescription() {
      let data = request.resource.data;
      return data.patientId is string &&
             data.patientName is string &&
             data.date is timestamp &&
             data.medicines is list;
    }
    
    function isValidInvoice() {
      let data = request.resource.data;
      return data.invoiceNumber is string &&
             data.patientId is string &&
             data.patientName is string &&
             data.date is timestamp &&
             data.treatments is list &&
             data.totalAmount is number;
    }

    match /doctors/{doctorId} {
      allow read, write: if true;
    }

    match /patients/{patientId} {
      allow read, write: if true;
    }
    
    match /appointments/{appointmentId} {
      allow read, write: if true;
    }
    
    match /prescriptions/{prescriptionId} {
      allow read, write: if true;
    }
    
    match /invoices/{invoiceId} {
      allow read, write: if true;
    }
    
    match /settings/{settingId} {
      allow read, write: if true;
    }
    
    match /dentalCharts/{patientId} {
      allow read, write: if true;
    }
    match /expenses/{expenseId} {
      allow read, write: if true;
    }
    
    match /expenseCategories/{categoryId} {
      allow read, write: if true;
    }
    
    match /labBills/{labBillId} {
      allow read, write: if true;
    }
    
    match /consultations/{consultationId} {
      allow read, write: if true;
    }
    
    match /media/{mediaId} {
      allow read, write: if true;
    }
  }
}
